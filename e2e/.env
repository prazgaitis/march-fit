# E2E Test Configuration
# Checked in with safe defaults. Override secrets in .env.local.

# Base URL for E2E tests (default: production)
E2E_BASE_URL=https://march.fit

# Dedicated E2E test challenge (write tests: sign up, log activities)
# Create this challenge in prod with the config in scripts/challenge-data/e2e-testing.json
E2E_CHALLENGE_ID=
E2E_CHALLENGE_INVITE_CODE=

# March 2026 challenge (read-only tests: leaderboard, category views)
# Uses an existing participant — set their password in .env.local
E2E_MARCH_2026_CHALLENGE_ID=js7039jtvp6z79d0r37h1x70qn8105zw
E2E_MARCH_2026_USER_EMAIL=paul@gocomplete.ai

# Shared password for E2E test users (override per-user passwords in .env.local)
E2E_USER_PASSWORD=
